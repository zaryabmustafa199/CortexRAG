# =============================================================================
# CortexRAG — Environment Configuration
# Copy this file to .env and fill in values before running docker compose
# NEVER commit .env to version control
# =============================================================================

# --- Application ---
APP_ENV=development                         # development | production
APP_VERSION=0.1.0
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3002", "http://localhost:8080", "http://127.0.0.1:3000", "http://127.0.0.1:3002", "http://127.0.0.1:8080"]      # JSON list of allowed origins

# --- Security (REQUIRED — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
JWT_SECRET=CHANGE_ME_generate_with_secrets_token_urlsafe_64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- PostgreSQL ---
POSTGRES_USER=cortexrag
POSTGRES_PASSWORD=cortexrag_dev_password
POSTGRES_DB=cortexrag
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://cortexrag:cortexrag_dev_password@postgres:5432/cortexrag

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- MinIO (S3-compatible) ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=cortexrag_minio
MINIO_SECRET_KEY=cortexrag_minio_secret
MINIO_BUCKET=cortexrag-documents
MINIO_SECURE=false

# --- Elasticsearch ---
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX_CHUNKS=cortexrag_chunks

# --- AI Provider (switch between "ollama" and "openai") ---
LLM_PROVIDER=ollama
LLM_MODEL=llama3
EMBED_MODEL=nomic-embed-text
EMBED_DIM=768

# --- Ollama (local — default) ---
OLLAMA_BASE_URL=http://ollama:11434

# --- OpenAI (optional cloud fallback — only used if LLM_PROVIDER=openai) ---
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_EMBED_DIM=1536

# --- Gemini (optional cloud choice — only used if LLM_PROVIDER=gemini) ---
GEMINI_API_KEY=
GEMINI_LLM_MODEL=gemini-3.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001
GEMINI_EMBED_DIM=768

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Observability (optional) ---
SENTRY_DSN=

# --- File Upload Limits ---
MAX_UPLOAD_SIZE_MB_FREE=10
MAX_UPLOAD_SIZE_MB_PRO=50
MAX_DOCS_FREE=5
MAX_DOCS_PRO=100
MAX_QUERIES_MONTHLY_FREE=100
MAX_QUERIES_MONTHLY_PRO=5000
